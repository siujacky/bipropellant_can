  11:src/mcp2515.c **** // MCP2515 Initialization and Detection
  12:src/mcp2515.c **** bool MCP2515_Detect(void) {
  13:src/mcp2515.c ****     // Initialize software SPI
  14:src/mcp2515.c ****     SoftSPI_Init();
  15:src/mcp2515.c ****     SoftSPI_SetMode(SPI_MODE0);
  16:src/mcp2515.c ****     
  17:src/mcp2515.c ****     // Small delay for MCP2515 to power up
  18:src/mcp2515.c ****     HAL_Delay(10);
  19:src/mcp2515.c ****     
  20:src/mcp2515.c ****     // Try to read CANSTAT register (should be 0x80 after reset - CONFIG mode)
  21:src/mcp2515.c ****     uint8_t canstat = MCP2515_ReadRegister(MCP2515_CANSTAT);
  22:src/mcp2515.c ****     
  23:src/mcp2515.c ****     if ((canstat & 0xE0) == 0x80) {
  24:src/mcp2515.c ****         // CANSTAT indicates CONFIG mode - MCP2515 detected
  25:src/mcp2515.c ****         return true;
  26:src/mcp2515.c ****     }
  27:src/mcp2515.c ****     
  28:src/mcp2515.c ****     // Try resetting the chip
  29:src/mcp2515.c ****     MCP2515_Reset();
  30:src/mcp2515.c ****     HAL_Delay(10);
  31:src/mcp2515.c ****     
  32:src/mcp2515.c ****     // Check again
  33:src/mcp2515.c ****     canstat = MCP2515_ReadRegister(MCP2515_CANSTAT);
ARM GAS  /tmp/ccJd5WrF.s 			page 2


  34:src/mcp2515.c ****     if ((canstat & 0xE0) == 0x80) {
  35:src/mcp2515.c ****         return true;
  36:src/mcp2515.c ****     }
  37:src/mcp2515.c ****     
  38:src/mcp2515.c ****     // Try read/write test to verify communication
  39:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_CNF1, 0xAA);
  40:src/mcp2515.c ****     uint8_t test = MCP2515_ReadRegister(MCP2515_CNF1);
  41:src/mcp2515.c ****     
  42:src/mcp2515.c ****     if (test == 0xAA) {
  43:src/mcp2515.c ****         MCP2515_WriteRegister(MCP2515_CNF1, 0x55);
  44:src/mcp2515.c ****         test = MCP2515_ReadRegister(MCP2515_CNF1);
  45:src/mcp2515.c ****         if (test == 0x55) {
  46:src/mcp2515.c ****             return true;
  47:src/mcp2515.c ****         }
  48:src/mcp2515.c ****     }
  49:src/mcp2515.c ****     
  50:src/mcp2515.c ****     // No MCP2515 detected - deinitialize SPI
  51:src/mcp2515.c ****     SoftSPI_Deinit();
  52:src/mcp2515.c ****     return false;
  53:src/mcp2515.c **** }
  54:src/mcp2515.c **** 
  55:src/mcp2515.c **** bool MCP2515_Init(uint8_t speed) {
  56:src/mcp2515.c ****     // Reset MCP2515
  57:src/mcp2515.c ****     MCP2515_Reset();
  58:src/mcp2515.c ****     HAL_Delay(10);
  59:src/mcp2515.c **** 
  60:src/mcp2515.c ****     // Set configuration mode
  61:src/mcp2515.c ****     if (!MCP2515_SetMode(MCP2515_MODE_CONFIG)) {
  62:src/mcp2515.c ****         return false;
  63:src/mcp2515.c ****     }
  64:src/mcp2515.c **** 
  65:src/mcp2515.c ****     // Configure bit timing
  66:src/mcp2515.c ****     if (!MCP2515_SetBitrate(speed)) {
  67:src/mcp2515.c ****         return false;
  68:src/mcp2515.c ****     }
  69:src/mcp2515.c **** 
  70:src/mcp2515.c ****     // Configure RX buffers - receive all messages.
  71:src/mcp2515.c ****     // RXB0CTRL: RXM=11 (accept all) | BUKT=1 (roll overflow into RXB1).
  72:src/mcp2515.c ****     // Without BUKT=1 a second frame arriving while RXB0 is full is DROPPED
  73:src/mcp2515.c ****     // (sets RX0OVR) instead of rolling over — silently loses CAN frames.
  74:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_RXB0CTRL, 0x64);  // 0x60 | BUKT(bit2)
  75:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_RXB1CTRL, 0x60);
  76:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_CANINTF, 0x00);
  77:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_CANINTE, 0x03);
  78:src/mcp2515.c **** 
  79:src/mcp2515.c ****     // Set normal mode
  80:src/mcp2515.c ****     if (!MCP2515_SetMode(MCP2515_MODE_NORMAL)) {
  81:src/mcp2515.c ****         return false;
  82:src/mcp2515.c ****     }
  83:src/mcp2515.c **** 
  84:src/mcp2515.c ****     return true;
  85:src/mcp2515.c **** }
  86:src/mcp2515.c **** 
  87:src/mcp2515.c **** void MCP2515_Reset(void) {
  88:src/mcp2515.c ****     MCP2515_Select();
  89:src/mcp2515.c ****     MCP2515_SPITransfer(MCP2515_CMD_RESET);
  90:src/mcp2515.c ****     MCP2515_Deselect();
ARM GAS  /tmp/ccJd5WrF.s 			page 3


  91:src/mcp2515.c ****     HAL_Delay(10);
  92:src/mcp2515.c **** }
  93:src/mcp2515.c **** 
  94:src/mcp2515.c **** bool MCP2515_SetMode(uint8_t mode) {
  95:src/mcp2515.c ****     MCP2515_ModifyRegister(MCP2515_CANCTRL, 0xE0, mode);
  96:src/mcp2515.c ****     
  97:src/mcp2515.c ****     // Verify mode change
  98:src/mcp2515.c ****     uint32_t timeout = HAL_GetTick() + 100;
  99:src/mcp2515.c ****     while (HAL_GetTick() < timeout) {
 100:src/mcp2515.c ****         uint8_t canstat = MCP2515_ReadRegister(MCP2515_CANSTAT);
 101:src/mcp2515.c ****         if ((canstat & 0xE0) == mode) {
 102:src/mcp2515.c ****             return true;
 103:src/mcp2515.c ****         }
 104:src/mcp2515.c ****         HAL_Delay(1);
 105:src/mcp2515.c ****     }
 106:src/mcp2515.c ****     
 107:src/mcp2515.c ****     return false;
 108:src/mcp2515.c **** }
 109:src/mcp2515.c **** 
 110:src/mcp2515.c **** bool MCP2515_SetBitrate(uint8_t speed) {
 111:src/mcp2515.c ****     // Bitrate configuration for 8 MHz crystal
 112:src/mcp2515.c ****     // CNF1: SJW=1, BRP
 113:src/mcp2515.c ****     // CNF2: BTLMODE=1, SAM=0, PHSEG1, PRSEG
 114:src/mcp2515.c ****     // CNF3: SOF=0, WAKFIL=0, PHSEG2
 115:src/mcp2515.c ****     
 116:src/mcp2515.c ****     uint8_t cnf1, cnf2, cnf3;
 117:src/mcp2515.c ****     
 118:src/mcp2515.c ****     switch (speed) {
 119:src/mcp2515.c ****         case MCP2515_SPEED_125KBPS:
 120:src/mcp2515.c ****             cnf1 = 0x01;  // BRP=1, SJW=1
 121:src/mcp2515.c ****             cnf2 = 0xB1;  // BTLMODE=1, PHSEG1=3, PRSEG=1
 122:src/mcp2515.c ****             cnf3 = 0x85;  // PHSEG2=5
 123:src/mcp2515.c ****             break;
 124:src/mcp2515.c ****             
 125:src/mcp2515.c ****         case MCP2515_SPEED_250KBPS:
 126:src/mcp2515.c ****             cnf1 = 0x00;  // BRP=0, SJW=1
 127:src/mcp2515.c ****             cnf2 = 0xB1;  // BTLMODE=1, PHSEG1=3, PRSEG=1
 128:src/mcp2515.c ****             cnf3 = 0x85;  // PHSEG2=5
 129:src/mcp2515.c ****             break;
 130:src/mcp2515.c ****             
 131:src/mcp2515.c ****         case MCP2515_SPEED_500KBPS:
 132:src/mcp2515.c ****             cnf1 = 0x00;  // BRP=0, SJW=1
 133:src/mcp2515.c ****             cnf2 = 0x90;  // BTLMODE=1, PHSEG1=2, PRSEG=0
 134:src/mcp2515.c ****             cnf3 = 0x82;  // PHSEG2=2
 135:src/mcp2515.c ****             break;
 136:src/mcp2515.c ****             
 137:src/mcp2515.c ****         case MCP2515_SPEED_1MBPS:
 138:src/mcp2515.c ****             cnf1 = 0x00;  // BRP=0, SJW=1
 139:src/mcp2515.c ****             cnf2 = 0x80;  // BTLMODE=1, PHSEG1=1, PRSEG=0
 140:src/mcp2515.c ****             cnf3 = 0x80;  // PHSEG2=1
 141:src/mcp2515.c ****             break;
 142:src/mcp2515.c ****             
 143:src/mcp2515.c ****         default:
 144:src/mcp2515.c ****             return false;
 145:src/mcp2515.c ****     }
 146:src/mcp2515.c ****     
 147:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_CNF1, cnf1);
ARM GAS  /tmp/ccJd5WrF.s 			page 4


 148:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_CNF2, cnf2);
 149:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_CNF3, cnf3);
 150:src/mcp2515.c ****     
 151:src/mcp2515.c ****     return true;
 152:src/mcp2515.c **** }
 153:src/mcp2515.c **** 
 154:src/mcp2515.c **** bool MCP2515_SendFrame(CAN_Frame *frame) {
 155:src/mcp2515.c ****     // Rotate through TXB0/TXB1/TXB2 so three rapid sends (speed + pos + batt)
 156:src/mcp2515.c ****     // never silently drop frames due to a still-pending buffer.
 157:src/mcp2515.c ****     // TXBnCTRL register addresses: TXB0=0x30, TXB1=0x40, TXB2=0x50.
 158:src/mcp2515.c ****     // TXBnSIDH load addresses:     TXB0=0x31, TXB1=0x41, TXB2=0x51.
 159:src/mcp2515.c ****     // RTS bitmask:                 TXB0=0x01, TXB1=0x02, TXB2=0x04.
 160:src/mcp2515.c ****     static uint8_t tx_slot = 0;
 161:src/mcp2515.c ****     static const uint8_t ctrl_addr[3] = { 0x30, 0x40, 0x50 };
 162:src/mcp2515.c ****     static const uint8_t sidh_addr[3] = { 0x31, 0x41, 0x51 };
 163:src/mcp2515.c ****     static const uint8_t rts_mask[3]  = { 0x01, 0x02, 0x04 };
 164:src/mcp2515.c **** 
 165:src/mcp2515.c ****     // Find a free TX buffer (TXREQ = bit2 = 0x04 per DS21801J §2.3).
 166:src/mcp2515.c ****     // WARNING: bit3 = TXERR (error flag), NOT TXREQ — using 0x08 would
 167:src/mcp2515.c ****     // treat error-flagged buffers as busy while missing genuinely busy ones.
 168:src/mcp2515.c ****     uint8_t slot = tx_slot;
 169:src/mcp2515.c ****     for (uint8_t attempt = 0; attempt < 3; attempt++) {
 170:src/mcp2515.c ****         uint8_t ctrl = MCP2515_ReadRegister(ctrl_addr[slot]);
 171:src/mcp2515.c ****         if (!(ctrl & 0x04)) {   // TXREQ clear — buffer free
 172:src/mcp2515.c ****             // Also clear any previous TXERR/ABTF to allow reuse
 173:src/mcp2515.c ****             if (ctrl & 0x18) {
 174:src/mcp2515.c ****                 MCP2515_ModifyRegister(ctrl_addr[slot], 0x18, 0x00);
 175:src/mcp2515.c ****             }
 176:src/mcp2515.c ****             break;
 177:src/mcp2515.c ****         }
 178:src/mcp2515.c ****         slot = (slot + 1) % 3;
 179:src/mcp2515.c ****         if (attempt == 2) {
 180:src/mcp2515.c ****             return false;   // All three buffers busy
 181:src/mcp2515.c ****         }
 182:src/mcp2515.c ****     }
 183:src/mcp2515.c ****     tx_slot = (slot + 1) % 3;  // Advance for next call
 184:src/mcp2515.c **** 
 185:src/mcp2515.c ****     // Build frame header
 186:src/mcp2515.c ****     uint8_t txbuf[13];
 187:src/mcp2515.c ****     uint8_t idx = 0;
 188:src/mcp2515.c **** 
 189:src/mcp2515.c ****     if (frame->extended) {
 190:src/mcp2515.c ****         txbuf[idx++] = (uint8_t)(frame->id >> 21);
 191:src/mcp2515.c ****         txbuf[idx++] = (uint8_t)(((frame->id >> 13) & 0xE0) |
 192:src/mcp2515.c ****                                   0x08 |                        // EXIDE bit
 193:src/mcp2515.c ****                                   ((frame->id >> 16) & 0x03));
 194:src/mcp2515.c ****         txbuf[idx++] = (uint8_t)(frame->id >> 8);
 195:src/mcp2515.c ****         txbuf[idx++] = (uint8_t)(frame->id);
 196:src/mcp2515.c ****     } else {
 197:src/mcp2515.c ****         txbuf[idx++] = (uint8_t)(frame->id >> 3);
 198:src/mcp2515.c ****         txbuf[idx++] = (uint8_t)(frame->id << 5);
 199:src/mcp2515.c ****         txbuf[idx++] = 0x00;
 200:src/mcp2515.c ****         txbuf[idx++] = 0x00;
 201:src/mcp2515.c ****     }
 202:src/mcp2515.c ****     txbuf[idx++] = frame->rtr ? (0x40 | frame->dlc) : frame->dlc;
 203:src/mcp2515.c ****     for (uint8_t i = 0; i < frame->dlc && i < 8; i++) {
 204:src/mcp2515.c ****         txbuf[idx++] = frame->data[i];
ARM GAS  /tmp/ccJd5WrF.s 			page 5


 205:src/mcp2515.c ****     }
 206:src/mcp2515.c **** 
 207:src/mcp2515.c ****     // Load TX buffer
 208:src/mcp2515.c ****     MCP2515_Select();
 209:src/mcp2515.c ****     MCP2515_SPITransfer(MCP2515_CMD_WRITE);
 210:src/mcp2515.c ****     MCP2515_SPITransfer(sidh_addr[slot]);
 211:src/mcp2515.c ****     for (uint8_t i = 0; i < idx; i++) {
 212:src/mcp2515.c ****         MCP2515_SPITransfer(txbuf[i]);
 213:src/mcp2515.c ****     }
 214:src/mcp2515.c ****     MCP2515_Deselect();
 215:src/mcp2515.c **** 
 216:src/mcp2515.c ****     // Request to send
 217:src/mcp2515.c ****     MCP2515_Select();
 218:src/mcp2515.c ****     MCP2515_SPITransfer(MCP2515_CMD_RTS | rts_mask[slot]);
 219:src/mcp2515.c ****     MCP2515_Deselect();
 220:src/mcp2515.c **** 
 221:src/mcp2515.c ****     // Post-RTS: check for immediate TXERR (bus-off or arbitration loss).
 222:src/mcp2515.c ****     // With OSM not set, MCP2515 auto-retries; poll is just a fast-fail
 223:src/mcp2515.c ****     // safety net after ~1ms so callers get an error code, not a silent hang.
 224:src/mcp2515.c ****     {
 225:src/mcp2515.c ****         volatile uint16_t timeout = 2000;
 226:src/mcp2515.c ****         while (timeout--) {
 227:src/mcp2515.c ****             uint8_t ctrl = MCP2515_ReadRegister(ctrl_addr[slot]);
 228:src/mcp2515.c ****             if (!(ctrl & 0x04)) break;         // TXREQ cleared — sent OK
 229:src/mcp2515.c ****             if (ctrl & 0x10) {                 // TXERR set — abort
 230:src/mcp2515.c ****                 MCP2515_ModifyRegister(ctrl_addr[slot], 0x08, 0x00); // clear TXREQ
 231:src/mcp2515.c ****                 return false;
 232:src/mcp2515.c ****             }
 233:src/mcp2515.c ****         }
 234:src/mcp2515.c ****     }
 235:src/mcp2515.c **** 
 236:src/mcp2515.c ****     return true;
 237:src/mcp2515.c **** }
 238:src/mcp2515.c **** 
 239:src/mcp2515.c **** bool MCP2515_ReceiveFrame(CAN_Frame *frame) {
 240:src/mcp2515.c ****     // Check RX status
 241:src/mcp2515.c ****     uint8_t status = MCP2515_GetRxStatus();
 242:src/mcp2515.c **** 
 243:src/mcp2515.c ****     if (!(status & 0xC0)) {
 244:src/mcp2515.c ****         // No message available
 245:src/mcp2515.c ****         return false;
 246:src/mcp2515.c ****     }
 247:src/mcp2515.c **** 
 248:src/mcp2515.c ****     uint8_t rxbuf[13];
 249:src/mcp2515.c **** 
 250:src/mcp2515.c ****     // Use "Read RX Buffer" instruction per DS21801J Table 12-2:
 251:src/mcp2515.c ****     //   0x90 = Read RXB0 from SIDH (RXB0 full, bit6 of RX_STATUS set)
 252:src/mcp2515.c ****     //   0x96 = Read RXB1 from SIDH (RXB1 full, bit7 set, bit6 clear)
 253:src/mcp2515.c ****     // Bug was 0x94 (Read RXB0 from data byte 0 — skips header, returns
 254:src/mcp2515.c ****     // garbage for RXB1 and does NOT auto-clear the RXB1 interrupt flag).
 255:src/mcp2515.c ****     uint8_t read_cmd = (status & 0x40) ? 0x90 : 0x96;
 256:src/mcp2515.c **** 
 257:src/mcp2515.c ****     MCP2515_Select();
 258:src/mcp2515.c ****     MCP2515_SPITransfer(read_cmd);
 259:src/mcp2515.c ****     for (uint8_t i = 0; i < 13; i++) {
 260:src/mcp2515.c ****         rxbuf[i] = MCP2515_SPITransfer(0xFF);
 261:src/mcp2515.c ****     }
ARM GAS  /tmp/ccJd5WrF.s 			page 6


 262:src/mcp2515.c ****     MCP2515_Deselect();
 263:src/mcp2515.c **** 
 264:src/mcp2515.c **** 
 265:src/mcp2515.c ****     // Parse frame
 266:src/mcp2515.c ****     if (rxbuf[1] & 0x08) {
 267:src/mcp2515.c ****         // Extended frame
 268:src/mcp2515.c ****         frame->extended = true;
 269:src/mcp2515.c ****         frame->id = ((uint32_t)rxbuf[0] << 21) |
 270:src/mcp2515.c ****                     ((uint32_t)(rxbuf[1] & 0xE0) << 13) |
 271:src/mcp2515.c ****                     ((uint32_t)(rxbuf[1] & 0x03) << 16) |
 272:src/mcp2515.c ****                     ((uint32_t)rxbuf[2] << 8) |
 273:src/mcp2515.c ****                     rxbuf[3];
 274:src/mcp2515.c ****     } else {
 275:src/mcp2515.c ****         // Standard frame
 276:src/mcp2515.c ****         frame->extended = false;
 277:src/mcp2515.c ****         frame->id = ((uint32_t)rxbuf[0] << 3) |
 278:src/mcp2515.c ****                     (rxbuf[1] >> 5);
 279:src/mcp2515.c ****     }
 280:src/mcp2515.c ****     
 281:src/mcp2515.c ****     frame->rtr = (rxbuf[4] & 0x40) ? true : false;
 282:src/mcp2515.c ****     frame->dlc = rxbuf[4] & 0x0F;
 283:src/mcp2515.c ****     
 284:src/mcp2515.c ****     // Copy data
 285:src/mcp2515.c ****     for (uint8_t i = 0; i < frame->dlc && i < 8; i++) {
 286:src/mcp2515.c ****         frame->data[i] = rxbuf[5 + i];
 287:src/mcp2515.c ****     }
 288:src/mcp2515.c ****     
 289:src/mcp2515.c ****     // Clear interrupt flag
 290:src/mcp2515.c ****     if (status & 0x40) {
 291:src/mcp2515.c ****         MCP2515_ModifyRegister(MCP2515_CANINTF, 0x01, 0x00);  // Clear RXB0 flag
 292:src/mcp2515.c ****     } else {
 293:src/mcp2515.c ****         MCP2515_ModifyRegister(MCP2515_CANINTF, 0x02, 0x00);  // Clear RXB1 flag
 294:src/mcp2515.c ****     }
 295:src/mcp2515.c ****     
 296:src/mcp2515.c ****     return true;
 297:src/mcp2515.c **** }
 298:src/mcp2515.c **** 
 299:src/mcp2515.c **** bool MCP2515_Available(void) {
 300:src/mcp2515.c ****     uint8_t status = MCP2515_GetRxStatus();
 301:src/mcp2515.c ****     return (status & 0xC0) != 0;
 302:src/mcp2515.c **** }
 303:src/mcp2515.c **** 
 304:src/mcp2515.c **** uint8_t MCP2515_ReadRegister(uint8_t address) {
 305:src/mcp2515.c ****     uint8_t result;
 306:src/mcp2515.c ****     
 307:src/mcp2515.c ****     MCP2515_Select();
 308:src/mcp2515.c ****     MCP2515_SPITransfer(MCP2515_CMD_READ);
 309:src/mcp2515.c ****     MCP2515_SPITransfer(address);
 310:src/mcp2515.c ****     result = MCP2515_SPITransfer(0xFF);
 311:src/mcp2515.c ****     MCP2515_Deselect();
 312:src/mcp2515.c ****     
 313:src/mcp2515.c ****     return result;
 314:src/mcp2515.c **** }
 315:src/mcp2515.c **** 
 316:src/mcp2515.c **** void MCP2515_WriteRegister(uint8_t address, uint8_t value) {
 317:src/mcp2515.c ****     MCP2515_Select();
 318:src/mcp2515.c ****     MCP2515_SPITransfer(MCP2515_CMD_WRITE);
ARM GAS  /tmp/ccJd5WrF.s 			page 7


 319:src/mcp2515.c ****     MCP2515_SPITransfer(address);
