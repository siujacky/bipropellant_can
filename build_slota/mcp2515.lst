 359:src/mcp2515.c **** // Loopback test - call AFTER software serial is initialized
 360:src/mcp2515.c **** void MCP2515_LoopbackTest(void) {
 361:src/mcp2515.c ****     extern void forceLog(char *message);
 362:src/mcp2515.c ****     char msg[100];
 363:src/mcp2515.c **** 
 364:src/mcp2515.c ****     forceLog("\r\n=== LOOPBACK TEST ===\r\n");
 365:src/mcp2515.c **** 
 366:src/mcp2515.c ****     // Save current mode
 367:src/mcp2515.c ****     uint8_t saved_canstat = MCP2515_ReadRegister(MCP2515_CANSTAT);
 368:src/mcp2515.c ****     sprintf(msg, "Current CANSTAT: 0x%02X\r\n", saved_canstat);
 369:src/mcp2515.c ****     forceLog(msg);
 370:src/mcp2515.c **** 
 371:src/mcp2515.c ****     // Enter config mode first
 372:src/mcp2515.c ****     if (!MCP2515_SetMode(MCP2515_MODE_CONFIG)) {
 373:src/mcp2515.c ****         forceLog("Failed to enter config mode!\r\n");
 374:src/mcp2515.c ****         return;
 375:src/mcp2515.c ****     }
ARM GAS  /tmp/ccJd5WrF.s 			page 8


 376:src/mcp2515.c **** 
 377:src/mcp2515.c ****     // Clear any pending RX
 378:src/mcp2515.c ****     MCP2515_WriteRegister(MCP2515_CANINTF, 0x00);
 379:src/mcp2515.c **** 
 380:src/mcp2515.c ****     // Enter loopback mode
 381:src/mcp2515.c ****     if (!MCP2515_SetMode(MCP2515_MODE_LOOPBACK)) {
 382:src/mcp2515.c ****         forceLog("Failed to enter loopback mode!\r\n");
 383:src/mcp2515.c ****         MCP2515_SetMode(MCP2515_MODE_NORMAL);
 384:src/mcp2515.c ****         return;
 385:src/mcp2515.c ****     }
 386:src/mcp2515.c ****     forceLog("Loopback mode set, sending test frame...\r\n");
 387:src/mcp2515.c **** 
 388:src/mcp2515.c ****     // Send a test frame (will loop back to RX)
 389:src/mcp2515.c ****     CAN_Frame test_frame;
 390:src/mcp2515.c ****     test_frame.id = 0x123;
 391:src/mcp2515.c ****     test_frame.extended = false;
 392:src/mcp2515.c ****     test_frame.rtr = false;
 393:src/mcp2515.c ****     test_frame.dlc = 4;
 394:src/mcp2515.c ****     test_frame.data[0] = 0xDE;
 395:src/mcp2515.c ****     test_frame.data[1] = 0xAD;
 396:src/mcp2515.c ****     test_frame.data[2] = 0xBE;
 397:src/mcp2515.c ****     test_frame.data[3] = 0xEF;
 398:src/mcp2515.c **** 
 399:src/mcp2515.c ****     if (MCP2515_SendFrame(&test_frame)) {
 400:src/mcp2515.c ****         forceLog("Test frame sent, waiting for loopback...\r\n");
 401:src/mcp2515.c ****         HAL_Delay(50);  // Wait for loopback
 402:src/mcp2515.c **** 
 403:src/mcp2515.c ****         // Check if received
 404:src/mcp2515.c ****         uint8_t rxstat = MCP2515_GetRxStatus();
 405:src/mcp2515.c ****         sprintf(msg, "RX status after loopback: 0x%02X\r\n", rxstat);
 406:src/mcp2515.c ****         forceLog(msg);
 407:src/mcp2515.c **** 
 408:src/mcp2515.c ****         if (rxstat & 0xC0) {
 409:src/mcp2515.c ****             // Read the RX buffer manually
 410:src/mcp2515.c ****             uint8_t rxbuf[13];
 411:src/mcp2515.c ****             MCP2515_Select();
 412:src/mcp2515.c ****             MCP2515_SPITransfer(MCP2515_CMD_READ);
 413:src/mcp2515.c ****             MCP2515_SPITransfer(0x61);  // RXB0SIDH
 414:src/mcp2515.c ****             for (int i = 0; i < 13; i++) {
 415:src/mcp2515.c ****                 rxbuf[i] = MCP2515_SPITransfer(0xFF);
 416:src/mcp2515.c ****             }
 417:src/mcp2515.c ****             MCP2515_Deselect();
 418:src/mcp2515.c **** 
 419:src/mcp2515.c ****             sprintf(msg, "Loopback RX: %02X %02X %02X %02X %02X | %02X %02X %02X %02X\r\n",
 420:src/mcp2515.c ****                     rxbuf[0], rxbuf[1], rxbuf[2], rxbuf[3], rxbuf[4],
 421:src/mcp2515.c ****                     rxbuf[5], rxbuf[6], rxbuf[7], rxbuf[8]);
 422:src/mcp2515.c ****             forceLog(msg);
 423:src/mcp2515.c **** 
 424:src/mcp2515.c ****             // Expected for ID=0x123: SIDH=0x24, SIDL=0x60, data at [5-8]
 425:src/mcp2515.c ****             if (rxbuf[0] == 0x24 && rxbuf[1] == 0x60 &&
 426:src/mcp2515.c ****                 rxbuf[5] == 0xDE && rxbuf[6] == 0xAD) {
 427:src/mcp2515.c ****                 forceLog("*** LOOPBACK SUCCESS! ***\r\n");
 428:src/mcp2515.c ****                 forceLog("SPI RX buffer reads work correctly.\r\n");
 429:src/mcp2515.c ****                 forceLog("Problem must be CAN bus reception.\r\n");
 430:src/mcp2515.c ****             } else {
 431:src/mcp2515.c ****                 forceLog("*** LOOPBACK FAILED - DATA MISMATCH! ***\r\n");
 432:src/mcp2515.c ****                 sprintf(msg, "Expected: 24 60 xx xx 04 DE AD BE EF\r\n");
ARM GAS  /tmp/ccJd5WrF.s 			page 9


 433:src/mcp2515.c ****                 forceLog(msg);
 434:src/mcp2515.c ****                 forceLog("SPI RX buffer reads are corrupted.\r\n");
 435:src/mcp2515.c ****             }
 436:src/mcp2515.c **** 
 437:src/mcp2515.c ****             // Clear RX flag
 438:src/mcp2515.c ****             MCP2515_ModifyRegister(MCP2515_CANINTF, 0x01, 0x00);
 439:src/mcp2515.c ****         } else {
 440:src/mcp2515.c ****             forceLog("No loopback message received!\r\n");
 441:src/mcp2515.c ****         }
 442:src/mcp2515.c ****     } else {
 443:src/mcp2515.c ****         forceLog("Failed to send test frame!\r\n");
 444:src/mcp2515.c ****     }
 445:src/mcp2515.c **** 
 446:src/mcp2515.c ****     forceLog("=== END LOOPBACK TEST ===\r\n");
 447:src/mcp2515.c **** 
 448:src/mcp2515.c ****     // Return to normal mode
 449:src/mcp2515.c ****     MCP2515_SetMode(MCP2515_MODE_NORMAL);
 450:src/mcp2515.c ****     forceLog("Returned to normal mode.\r\n\r\n");
 451:src/mcp2515.c **** }
