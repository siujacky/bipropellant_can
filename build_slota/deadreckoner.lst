  22:src/deadreckoner.c **** 
  23:src/deadreckoner.c **** DEADRECKONER *DeadReckoner(volatile int32_t *pLeftTicks, volatile int32_t *pRightTicks, double tick
  24:src/deadreckoner.c ****     // get zeroed structure
  25:src/deadreckoner.c ****     DEADRECKONER *d = calloc(1, sizeof(DEADRECKONER));
  26:src/deadreckoner.c **** 
  27:src/deadreckoner.c **** 	d->leftOmegaDirection = 1;
  28:src/deadreckoner.c **** 	d->rightOmegaDirection = 1;
  29:src/deadreckoner.c **** 
  30:src/deadreckoner.c **** 	d->leftTicks = pLeftTicks;
  31:src/deadreckoner.c **** 	d->rightTicks = pRightTicks;
  32:src/deadreckoner.c **** 	d->ticksPerRev = ticksPerRev;
