  33:src/deadreckoner.c **** 	d->radius = wheelDiameter/2;
  34:src/deadreckoner.c **** 	d->length = wheelBase;
  35:src/deadreckoner.c **** 	d->toRadPerSec = TIMER_RES * TWO_PI / d->ticksPerRev;
  36:src/deadreckoner.c **** 
  37:src/deadreckoner.c ****     d->useDegrees = useDegrees;
  38:src/deadreckoner.c **** 
  39:src/deadreckoner.c ****     return d;
  40:src/deadreckoner.c **** }
