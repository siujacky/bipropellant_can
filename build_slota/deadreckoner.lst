   9:src/deadreckoner.c **** #define WHEEL_FORWARD 1
  10:src/deadreckoner.c **** #define WHEEL_REVERSE -1
  11:src/deadreckoner.c **** 
  12:src/deadreckoner.c **** #define PI (3.14159265359)
  13:src/deadreckoner.c **** #define TWO_PI (3.14159265359*2)
  14:src/deadreckoner.c **** 
  15:src/deadreckoner.c **** // if we had microseconds, set TIMER_RES to 1000000
