  42:src/deadreckoner.c **** void DeadReckoner_Destroy( DEADRECKONER **d ) {
  43:src/deadreckoner.c ****     if (d) {
  44:src/deadreckoner.c ****         if (*d) {
  45:src/deadreckoner.c ****             free(*d);
