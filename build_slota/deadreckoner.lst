  96:src/deadreckoner.c **** 
  97:src/deadreckoner.c **** void computeAngularVelocities(DEADRECKONER *d) {
  98:src/deadreckoner.c **** 	// Time elapsed after computing the angular velocity previously.
  99:src/deadreckoner.c **** 	// change in time is defined as previous - current to prevent round off error.
 100:src/deadreckoner.c **** 	d->dt_omega = getChange(d->prevWheelComputeTime, micros()); // in milliseconds
 101:src/deadreckoner.c **** 
 102:src/deadreckoner.c **** 	double changeLeftTicks = *d->leftTicks - d->leftTicksPrev;//getChange(*d->leftTicks, d->leftTicksP
 103:src/deadreckoner.c **** 	double changeRightTicks = *d->rightTicks - d->rightTicksPrev;//getChange(*d->rightTicks, d->rightT
 104:src/deadreckoner.c **** 
 105:src/deadreckoner.c **** 	d->wl = d->leftOmegaDirection * changeLeftTicks / d->dt_omega * d->toRadPerSec;
 106:src/deadreckoner.c **** 	d->wr = d->rightOmegaDirection * changeRightTicks / d->dt_omega * d->toRadPerSec;
 107:src/deadreckoner.c **** 
 108:src/deadreckoner.c **** 	//double toRPM = 30.0 / PI;
 109:src/deadreckoner.c **** 	//Serial.print("\twl: "); Serial.print(wl*toRPM, 5);
 110:src/deadreckoner.c **** 	//Serial.print("\twr: "); Serial.print(wr*toRPM, 5);
 111:src/deadreckoner.c **** 	//Serial.print("\tdt: "); Serial.print(dt_omega);
 112:src/deadreckoner.c **** 	//Serial.print("\tlt: "); Serial.print(changeLeftTicks);
 113:src/deadreckoner.c **** 	//Serial.print("\trt: "); Serial.println(changeRightTicks);
 114:src/deadreckoner.c **** 
 115:src/deadreckoner.c **** 	d->leftTicksPrev = *d->leftTicks;
 116:src/deadreckoner.c **** 	d->rightTicksPrev = *d->rightTicks;
 117:src/deadreckoner.c **** 
 118:src/deadreckoner.c **** 	d->prevWheelComputeTime = micros();
 119:src/deadreckoner.c **** }
