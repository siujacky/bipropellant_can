  48:src/deadreckoner.c ****     }
  49:src/deadreckoner.c **** }
  50:src/deadreckoner.c **** 
  51:src/deadreckoner.c **** void setXYT(DEADRECKONER *d, double x, double y, double t) {
  52:src/deadreckoner.c **** 	d->xc = x;
  53:src/deadreckoner.c **** 	d->yc = y;
  54:src/deadreckoner.c ****     if (d->useDegrees){
  55:src/deadreckoner.c **** 	    d->theta = (t/180.0)*PI;
  56:src/deadreckoner.c ****     } else {
  57:src/deadreckoner.c **** 	    d->theta = t;
  58:src/deadreckoner.c ****     }
  59:src/deadreckoner.c **** }
  60:src/deadreckoner.c **** 
  61:src/deadreckoner.c **** void getXYT(DEADRECKONER *d, double *x, double *y, double *t) {
  62:src/deadreckoner.c **** 	if (x) *x = d->xc;
  63:src/deadreckoner.c **** 	if (y) *y = d->yc;
  64:src/deadreckoner.c **** 	if (t) {
  65:src/deadreckoner.c ****         if (d->useDegrees){
  66:src/deadreckoner.c ****             *t = (d->theta/PI)*180.0;
  67:src/deadreckoner.c ****         } else {
  68:src/deadreckoner.c ****             *t = d->theta;
  69:src/deadreckoner.c ****         }
  70:src/deadreckoner.c ****     }
  71:src/deadreckoner.c **** }
  72:src/deadreckoner.c **** 
  73:src/deadreckoner.c **** 
  74:src/deadreckoner.c **** void getWl(DEADRECKONER *d, double *wl, double *wr) {
  75:src/deadreckoner.c **** 	// TODO: Check this
  76:src/deadreckoner.c **** 	if (wl) *wl = d->wl * d->dt_omega / (UNSIGNED_LONG_MAX - d->dt_omega);
  77:src/deadreckoner.c **** 	if (wr) *wr = d->wr * d->dt_omega / (UNSIGNED_LONG_MAX - d->dt_omega);
  78:src/deadreckoner.c **** }
  79:src/deadreckoner.c **** 
  80:src/deadreckoner.c **** 
  81:src/deadreckoner.c **** void getW(DEADRECKONER *d, double *w) {
  82:src/deadreckoner.c **** 	if (w) *w = d->w * d->dt_integration / (UNSIGNED_LONG_MAX - d->dt_integration);
  83:src/deadreckoner.c **** }
  84:src/deadreckoner.c **** 
  85:src/deadreckoner.c **** 
