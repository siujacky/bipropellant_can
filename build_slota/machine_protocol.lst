 102:src/hbprotocol/machine_protocol.c **** void protocol_SOM_decode(PROTOCOL_MSG3 *msg) {
 103:src/hbprotocol/machine_protocol.c **** 
 104:src/hbprotocol/machine_protocol.c ****     if(0b10000000 & msg->cmd) {
 105:src/hbprotocol/machine_protocol.c ****         msg->SOM = PROTOCOL_SOM_ACK;
 106:src/hbprotocol/machine_protocol.c ****     } else {
 107:src/hbprotocol/machine_protocol.c ****         msg->SOM = PROTOCOL_SOM_NOACK;
 108:src/hbprotocol/machine_protocol.c ****     }
 109:src/hbprotocol/machine_protocol.c **** 
 110:src/hbprotocol/machine_protocol.c ****     msg->cmd = 0b01111111 & msg->cmd;
 111:src/hbprotocol/machine_protocol.c **** }
 112:src/hbprotocol/machine_protocol.c **** 
 113:src/hbprotocol/machine_protocol.c **** int protocol_SOM_encode(PROTOCOL_MSG3 *msg) {
 114:src/hbprotocol/machine_protocol.c **** 
 115:src/hbprotocol/machine_protocol.c ****     if( msg->SOM == PROTOCOL_SOM_ACK ) {
 116:src/hbprotocol/machine_protocol.c ****         msg->cmd = msg->cmd | 0b10000000;
 117:src/hbprotocol/machine_protocol.c ****         msg->SOM = PROTOCOL_SOM;
 118:src/hbprotocol/machine_protocol.c ****         return 0; // all went well
 119:src/hbprotocol/machine_protocol.c **** 
 120:src/hbprotocol/machine_protocol.c ****     } else  if( msg->SOM == PROTOCOL_SOM_NOACK ) {
 121:src/hbprotocol/machine_protocol.c ****         msg->cmd = msg->cmd & 0b01111111;
 122:src/hbprotocol/machine_protocol.c ****         msg->SOM = PROTOCOL_SOM;
 123:src/hbprotocol/machine_protocol.c ****         return 0; // all went well
 124:src/hbprotocol/machine_protocol.c ****     }
 125:src/hbprotocol/machine_protocol.c **** 
 126:src/hbprotocol/machine_protocol.c ****     return 1; // Unknowm SOM
 127:src/hbprotocol/machine_protocol.c **** 
 128:src/hbprotocol/machine_protocol.c **** }
