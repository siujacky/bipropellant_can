 583:src/can_bus.c ****     // Boot message format:
 584:src/can_bus.c ****     // [0-1]: Board ID (uint16_t)
 585:src/can_bus.c ****     // [2-3]: Reserved for battery voltage (set to 0 at boot)
 586:src/can_bus.c ****     // [4-5]: Reserved for temperature (set to 0 at boot)
 587:src/can_bus.c ****     // [6]: Firmware version major
 588:src/can_bus.c ****     // [7]: Firmware version minor
