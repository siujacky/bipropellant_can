 109:src/can_bus.c **** 
 110:src/can_bus.c **** // Function to detect MCP2515 and initialize CAN bus
 111:src/can_bus.c **** bool CAN_AutoDetectAndInit(void) {
 112:src/can_bus.c **** #ifdef ENABLE_CAN_BUS
 113:src/can_bus.c ****     char msg[128];
 114:src/can_bus.c ****     
 115:src/can_bus.c ****     forceLog("\r\n=== CAN Bus Initialization ===\r\n");
 116:src/can_bus.c ****     forceLog("Detecting MCP2515 module...\r\n");
 117:src/can_bus.c ****     
 118:src/can_bus.c ****     // Initialize CAN IDs based on board ID
 119:src/can_bus.c ****     CAN_Init_IDs();
 120:src/can_bus.c ****     
 121:src/can_bus.c ****     // Try to detect MCP2515
 122:src/can_bus.c ****     if (MCP2515_Detect()) {
 123:src/can_bus.c ****         forceLog("MCP2515 DETECTED!\r\n");
 124:src/can_bus.c ****         
 125:src/can_bus.c ****         // MCP2515 detected - initialize CAN bus
 126:src/can_bus.c ****         sprintf(msg, "Initializing CAN at %d kbps...\r\n", 
 127:src/can_bus.c ****                 CAN_SPEED == MCP2515_SPEED_125KBPS ? 125 :
 128:src/can_bus.c ****                 CAN_SPEED == MCP2515_SPEED_250KBPS ? 250 :
 129:src/can_bus.c ****                 CAN_SPEED == MCP2515_SPEED_500KBPS ? 500 : 1000);
 130:src/can_bus.c ****         forceLog(msg);
 131:src/can_bus.c ****         
 132:src/can_bus.c ****         if (MCP2515_Init(CAN_SPEED)) {
 133:src/can_bus.c ****             /* SoftSPI_Init disabled TIM1/TIM8 IRQs to prevent motor-control
 134:src/can_bus.c ****              * timer interference during SPI pin setup. Re-enable now. */
 135:src/can_bus.c ****             forceLog("CAN bus initialized successfully\r\n");
 136:src/can_bus.c ****             can_mode_active = true;
 137:src/can_bus.c ****             usart_mode_active = false;
 138:src/can_bus.c ****             
 139:src/can_bus.c ****             // Reset statistics
 140:src/can_bus.c ****             memset(&can_stats, 0, sizeof(can_stats));
 141:src/can_bus.c **** 
 142:src/can_bus.c ****             // Now that CAN is working, enable software serial on PA13/PA14
 143:src/can_bus.c ****             // This disables SWD but CAN is confirmed working
 144:src/can_bus.c ****             #if defined(SOFTWARE_SERIAL) && defined(SOFTWARE_SERIAL_DEFERRED_INIT)
 145:src/can_bus.c ****             forceLog("Enabling software serial on PA13/PA14...\r\n");
 146:src/can_bus.c ****             SoftwareSerialInit();
 147:src/can_bus.c ****             software_serial_ready = true;  // Mark Software Serial as ready
 148:src/can_bus.c ****             
 149:src/can_bus.c ****             // Test PA13 output - blink it a few times to verify it's working
 150:src/can_bus.c ****             for(int i = 0; i < 10; i++) {
 151:src/can_bus.c ****                 HAL_GPIO_WritePin(SOFTWARE_SERIAL_TX_PORT, SOFTWARE_SERIAL_TX_PIN, 1);
 152:src/can_bus.c ****                 for(volatile int j = 0; j < 50000; j++);  // ~5ms
 153:src/can_bus.c ****                 HAL_GPIO_WritePin(SOFTWARE_SERIAL_TX_PORT, SOFTWARE_SERIAL_TX_PIN, 0);
 154:src/can_bus.c ****                 for(volatile int j = 0; j < 50000; j++);  // ~5ms
 155:src/can_bus.c ****             }
 156:src/can_bus.c ****             forceLog("PA13 test blink complete\r\n");
ARM GAS  /tmp/ccC7I5pD.s 			page 7


 157:src/can_bus.c **** 
 158:src/can_bus.c ****             // Run SPI diagnostic NOW (after serial is ready)
 159:src/can_bus.c ****             {
 160:src/can_bus.c ****                 char dmsg[100];
 161:src/can_bus.c ****                 forceLog("\r\n=== SPI DIAGNOSTIC ===\r\n");
 162:src/can_bus.c **** 
 163:src/can_bus.c ****                 // Single byte reads
 164:src/can_bus.c ****                 uint8_t cnf1 = MCP2515_ReadRegister(MCP2515_CNF1);
 165:src/can_bus.c ****                 uint8_t cnf2 = MCP2515_ReadRegister(MCP2515_CNF2);
 166:src/can_bus.c ****                 uint8_t cnf3 = MCP2515_ReadRegister(MCP2515_CNF3);
 167:src/can_bus.c ****                 sprintf(dmsg, "Single: CNF1=0x%02X CNF2=0x%02X CNF3=0x%02X\r\n", cnf1, cnf2, cnf3);
 168:src/can_bus.c ****                 forceLog(dmsg);
 169:src/can_bus.c **** 
 170:src/can_bus.c ****                 // Multi-byte read of same registers
 171:src/can_bus.c ****                 uint8_t multi[3];
 172:src/can_bus.c ****                 extern void SoftSPI_CS_Low(void);
 173:src/can_bus.c ****                 extern void SoftSPI_CS_High(void);
 174:src/can_bus.c ****                 extern uint8_t SoftSPI_Transfer(uint8_t data);
 175:src/can_bus.c ****                 SoftSPI_CS_Low();
 176:src/can_bus.c ****                 SoftSPI_Transfer(0x03);  // READ
 177:src/can_bus.c ****                 SoftSPI_Transfer(0x28);  // CNF3 addr
 178:src/can_bus.c ****                 multi[0] = SoftSPI_Transfer(0xFF);
 179:src/can_bus.c ****                 multi[1] = SoftSPI_Transfer(0xFF);
 180:src/can_bus.c ****                 multi[2] = SoftSPI_Transfer(0xFF);
 181:src/can_bus.c ****                 SoftSPI_CS_High();
 182:src/can_bus.c ****                 sprintf(dmsg, "Multi:  CNF3=0x%02X CNF2=0x%02X CNF1=0x%02X\r\n", multi[0], multi[1]
 183:src/can_bus.c ****                 forceLog(dmsg);
 184:src/can_bus.c **** 
 185:src/can_bus.c ****                 // Check CANSTAT
 186:src/can_bus.c ****                 uint8_t canstat = MCP2515_ReadRegister(MCP2515_CANSTAT);
 187:src/can_bus.c ****                 sprintf(dmsg, "CANSTAT=0x%02X (0x00=normal)\r\n", canstat);
 188:src/can_bus.c ****                 forceLog(dmsg);
 189:src/can_bus.c ****                 forceLog("======================\r\n\r\n");
 190:src/can_bus.c ****             }
 191:src/can_bus.c ****             #endif
 192:src/can_bus.c **** 
 193:src/can_bus.c ****             forceLog("CAN controller mode ACTIVE\r\n");
 194:src/can_bus.c ****             forceLog("NOTE: All debug messages will now appear automatically.\r\n");
 195:src/can_bus.c ****             forceLog("      No need to send 'E' or unlock commands.\r\n\r\n");
 196:src/can_bus.c ****             return true;
 197:src/can_bus.c ****         } else {
 198:src/can_bus.c ****             forceLog("ERROR: CAN initialization failed\r\n");
 199:src/can_bus.c ****         }
 200:src/can_bus.c ****     } else {
 201:src/can_bus.c ****         forceLog("MCP2515 NOT DETECTED\r\n");
 202:src/can_bus.c ****     }
 203:src/can_bus.c ****     
 204:src/can_bus.c ****     can_mode_active = false;
 205:src/can_bus.c **** 
 206:src/can_bus.c ****     // Fall back to USART mode
 207:src/can_bus.c ****     CAN_Fallback_To_USART();
 208:src/can_bus.c ****     return false;
 209:src/can_bus.c **** #else
 210:src/can_bus.c ****     // CAN not enabled - use USART by default
 211:src/can_bus.c ****     can_mode_active = false;
 212:src/can_bus.c ****     CAN_Fallback_To_USART();
 213:src/can_bus.c ****     return false;
ARM GAS  /tmp/ccC7I5pD.s 			page 8


 214:src/can_bus.c **** #endif
