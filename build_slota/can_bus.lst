 442:src/can_bus.c ****     // Clamp position before packing into CAN frame.
 443:src/can_bus.c ****     // HallPosn_mm is a running accumulator; on encoder wrap (e.g. >100km
 444:src/can_bus.c ****     // travel) it overflows int32_t and produces a discontinuous jump on
 445:src/can_bus.c ****     // the CAN bus that confuses odometry on the receiver side.
 446:src/can_bus.c ****     // Clamp to ±100,000,000 mm (±100 km) — practical rover range.
