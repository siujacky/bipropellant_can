  23:src/pid.c     **** {
  24:src/pid.c     **** 	pid->input = in;
  25:src/pid.c     **** 	pid->output = out;
  26:src/pid.c     **** 	pid->setpoint = set;
  27:src/pid.c     **** 	pid->automode = false;
