  88:src/hbprotocol/protocol.c **** 
  89:src/hbprotocol/protocol.c ****         newMsg.lenPayload = 1; // 1 only
  90:src/hbprotocol/protocol.c ****         newMsg.cmd = PROTOCOL_CMD_WRITEVALRESPONSE; // mark as response
  91:src/hbprotocol/protocol.c ****         newMsg.content[0] = 1; // say we wrote it
