  98:src/hbprotocol/protocol.c **** void fn_defaultProcessing ( PROTOCOL_STAT *s, PARAMSTAT *param, unsigned char cmd, PROTOCOL_MSG3ful
  99:src/hbprotocol/protocol.c ****     switch (cmd) {
 100:src/hbprotocol/protocol.c ****         case PROTOCOL_CMD_READVAL:
 101:src/hbprotocol/protocol.c ****             protocol_process_ReadAndSendValue(s, msg);
 102:src/hbprotocol/protocol.c ****             break;
 103:src/hbprotocol/protocol.c ****         case PROTOCOL_CMD_SILENTREAD:
