 462:src/hbprotocol/protocol.c **** // Set entry in params
 463:src/hbprotocol/protocol.c **** int setParam(PROTOCOL_STAT *s, PARAMSTAT *param) {
 464:src/hbprotocol/protocol.c **** 
 465:src/hbprotocol/protocol.c ****     if(param == NULL) return 1;   // Failure, got NULL pointer
 466:src/hbprotocol/protocol.c **** 
 467:src/hbprotocol/protocol.c ****     // Check if len can actually be received
 468:src/hbprotocol/protocol.c ****     if( param->len > sizeof( ((PROTOCOL_MSG3full *)0)->content ) ) {
 469:src/hbprotocol/protocol.c ****         return 1;                 // Too long, Failure
 470:src/hbprotocol/protocol.c ****     }
 471:src/hbprotocol/protocol.c **** 
 472:src/hbprotocol/protocol.c ****     if( param->code < (sizeof(s->params)/sizeof(s->params[0])) ) {
 473:src/hbprotocol/protocol.c ****         s->params[param->code] = param;
 474:src/hbprotocol/protocol.c ****         return 0; // Successfully assigned
 475:src/hbprotocol/protocol.c ****     }
 476:src/hbprotocol/protocol.c **** 
 477:src/hbprotocol/protocol.c ****     return 1; // Failure, index too big.
 478:src/hbprotocol/protocol.c **** }
