  46:src/hbprotocol/protocol.c **** void protocol_process_ReadValue(PROTOCOL_STAT *s, PROTOCOL_MSG3full *msg) {
  47:src/hbprotocol/protocol.c ****     if(msg) {
  48:src/hbprotocol/protocol.c ****         unsigned char *src = s->params[msg->code]->ptr;
  49:src/hbprotocol/protocol.c ****         for (int j = 0; j < s->params[msg->code]->len; j++){
  50:src/hbprotocol/protocol.c ****             msg->content[j] = *(src++);
  51:src/hbprotocol/protocol.c ****         }
  52:src/hbprotocol/protocol.c ****     }
  53:src/hbprotocol/protocol.c **** }
  54:src/hbprotocol/protocol.c **** 
  55:src/hbprotocol/protocol.c **** void protocol_process_ReadAndSendValue(PROTOCOL_STAT *s, PROTOCOL_MSG3full *msg) {
  56:src/hbprotocol/protocol.c ****     if(msg) {
  57:src/hbprotocol/protocol.c ****         protocol_process_ReadValue(s, msg);
  58:src/hbprotocol/protocol.c **** 
  59:src/hbprotocol/protocol.c ****         PROTOCOL_MSG3full newMsg;
  60:src/hbprotocol/protocol.c ****         memcpy(&newMsg, msg, sizeof(PROTOCOL_MSG3full));
  61:src/hbprotocol/protocol.c **** 
  62:src/hbprotocol/protocol.c ****         newMsg.lenPayload = s->params[msg->code]->len;  // command + code + data len only
  63:src/hbprotocol/protocol.c ****         newMsg.cmd = PROTOCOL_CMD_READVALRESPONSE; // mark as response
  64:src/hbprotocol/protocol.c ****         // send back with 'read' command plus data like write.
  65:src/hbprotocol/protocol.c ****         protocol_post(s, &newMsg);
  66:src/hbprotocol/protocol.c ****     }
  67:src/hbprotocol/protocol.c **** }
  68:src/hbprotocol/protocol.c **** 
  69:src/hbprotocol/protocol.c **** void protocol_process_WriteValue(PROTOCOL_STAT *s, PROTOCOL_MSG3full *msg) {
  70:src/hbprotocol/protocol.c ****     if(msg) {
  71:src/hbprotocol/protocol.c ****         unsigned char *dest = s->params[msg->code]->ptr;
  72:src/hbprotocol/protocol.c ****         // ONLY copy what we have, else we're stuffing random data in.
  73:src/hbprotocol/protocol.c ****         // e.g. is setting posn, structure is 8 x 4 bytes,
  74:src/hbprotocol/protocol.c ****         // but we often only want to set the first 8
  75:src/hbprotocol/protocol.c ****         for (int j = 0; ((j < s->params[msg->code]->len) && (j < (msg->lenPayload))); j++){
  76:src/hbprotocol/protocol.c ****             *(dest++) = msg->content[j];
  77:src/hbprotocol/protocol.c ****         }
  78:src/hbprotocol/protocol.c ****     }
  79:src/hbprotocol/protocol.c **** }
  80:src/hbprotocol/protocol.c **** 
  81:src/hbprotocol/protocol.c **** void protocol_process_cmdWritevalAndRespond(PROTOCOL_STAT *s, PROTOCOL_MSG3full *msg) {
