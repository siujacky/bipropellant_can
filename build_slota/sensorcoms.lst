  11:src/sensorcoms.c **** /////////////////////////////////////////////////////////////////////////////////////
  12:src/sensorcoms.c **** // this file encapsulates coms with the original sensor boards
  13:src/sensorcoms.c **** // these use the 9 bit USART mode, sending 0x100 to signal the END of a comms frame
  14:src/sensorcoms.c **** // it uses CONTROL_SENSOR, CONTROL_BAUD (52177 for GD32 based YST board) and DEBUG_SERIAL_SENSOR
  15:src/sensorcoms.c **** // Implements Interrupt driven USART2 & USART3 with buffers,
  16:src/sensorcoms.c **** // and uses 9 bit serial.
  17:src/sensorcoms.c **** /////////////////////////////////////////////////////////////////////////////////////
  18:src/sensorcoms.c **** 
  19:src/sensorcoms.c **** #ifdef CONTROL_SENSOR
  20:src/sensorcoms.c **** 
