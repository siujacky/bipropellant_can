  51:src/ascii_proto_funcs.c **** //////////////////////////////////////////////////////////
  52:src/ascii_proto_funcs.c **** //
  53:src/ascii_proto_funcs.c **** // ASCII protocol:
  54:src/ascii_proto_funcs.c **** // this accepts command sup to 10 bytes long terminated with CR.
  55:src/ascii_proto_funcs.c **** // one of these commands (I) can enable an 'immediate' mode.
  56:src/ascii_proto_funcs.c **** // In 'immediate' mode, keypresses cause immediate action;
  57:src/ascii_proto_funcs.c **** // for example, controlling speed, or getting real-time feedback.
  58:src/ascii_proto_funcs.c **** //
  59:src/ascii_proto_funcs.c **** //////////////////////////////////////////////////////////
  60:src/ascii_proto_funcs.c **** 
  61:src/ascii_proto_funcs.c **** 
  62:src/ascii_proto_funcs.c **** ///////////////////////////////////////////////
