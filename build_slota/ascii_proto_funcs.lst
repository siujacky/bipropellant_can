  65:src/ascii_proto_funcs.c **** extern SENSOR_DATA sensor_data[2];
  66:src/ascii_proto_funcs.c **** extern int sensor_control;
  67:src/ascii_proto_funcs.c **** extern int sensor_stabilise;
  68:src/ascii_proto_funcs.c **** #endif
