 173:src/ascii_proto_funcs.c **** int immediate_stop(PROTOCOL_STAT *s, char byte, char *ascii_out) {
 174:src/ascii_proto_funcs.c ****     speedB = 0;
 175:src/ascii_proto_funcs.c ****     steerB = 0;
 176:src/ascii_proto_funcs.c ****     PWMData.pwm[1] = CLAMP(speedB * SPEED_COEFFICIENT -  steerB * STEER_COEFFICIENT, -1000, 1000);
 177:src/ascii_proto_funcs.c ****     PWMData.pwm[0] = CLAMP(speedB * SPEED_COEFFICIENT +  steerB * STEER_COEFFICIENT, -1000, 1000);
 178:src/ascii_proto_funcs.c ****     SpeedData.wanted_speed_mm_per_sec[0] = SpeedData.wanted_speed_mm_per_sec[1] = speedB;
 179:src/ascii_proto_funcs.c ****     HallData[0].HallSpeed_mm_per_s = HallData[1].HallSpeed_mm_per_s = 0;
 180:src/ascii_proto_funcs.c ****     dspeeds[0] = dspeeds[1] = speedB;
 181:src/ascii_proto_funcs.c ****     pwms[0] = pwms[1] = speedB;
 182:src/ascii_proto_funcs.c ****     PosnData.wanted_posn_mm[0] = HallData[0].HallPosn_mm;
 183:src/ascii_proto_funcs.c ****     PosnData.wanted_posn_mm[1] = HallData[1].HallPosn_mm;
 184:src/ascii_proto_funcs.c **** #ifdef CONTROL_SENSOR
 185:src/ascii_proto_funcs.c ****     sensor_control = 0;
 186:src/ascii_proto_funcs.c **** #endif
 187:src/ascii_proto_funcs.c ****     enable = 0;
 188:src/ascii_proto_funcs.c ****     sprintf(ascii_out, "Stop set\r\n");
 189:src/ascii_proto_funcs.c ****     return 1;
 190:src/ascii_proto_funcs.c **** }
