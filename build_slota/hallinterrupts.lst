  27:src/hallinterrupts.c **** //////////////////////////////////////////////////////////////
  28:src/hallinterrupts.c **** // file reads Hall sensors, and gets Distance and Speed.
ARM GAS  /tmp/cc0GIl0a.s 			page 2


  29:src/hallinterrupts.c **** // Uses:
  30:src/hallinterrupts.c **** // EXTI15_10_IRQHandler
  31:src/hallinterrupts.c **** // EXTI9_5_IRQHandler
  32:src/hallinterrupts.c **** // TIM4 running at 100khz, reloading 0xFFFF
  33:src/hallinterrupts.c **** // TIM4_IRQHandler
  34:src/hallinterrupts.c **** //////////////////////////////////////////////////////////////
  35:src/hallinterrupts.c **** // Usage: just start with HallInterruptinit(void) and
  36:src/hallinterrupts.c **** // read results from HALL_DATA_STRUCT HallData[2];
  37:src/hallinterrupts.c **** //////////////////////////////////////////////////////////////
  38:src/hallinterrupts.c **** // Notes:
  39:src/hallinterrupts.c **** // for distance measurement and speed calculations, it defaults to 6.5" wheels.
  40:src/hallinterrupts.c **** // this may be changed by calling:
  41:src/hallinterrupts.c **** // void HallInterruptSetWheelDiameterInches(float inches);
  42:src/hallinterrupts.c **** // or
  43:src/hallinterrupts.c **** // void HallInterruptSetWheelDiameterMM(float mm);
  44:src/hallinterrupts.c **** //
  45:src/hallinterrupts.c **** // if you wish to reset the values in the structure completely, use:
  46:src/hallinterrupts.c **** // void HallInterruptReset();
  47:src/hallinterrupts.c **** // if you wish to read distance and spped, and optionally reset distance to zero,
  48:src/hallinterrupts.c **** // then use:
  49:src/hallinterrupts.c **** // void HallInterruptReadPosn( HALL_POSN *p, int Reset );
  50:src/hallinterrupts.c **** //
  51:src/hallinterrupts.c **** // NOTE: if the hall pins are reconfigured to NOT be in the set 5-9, 10-15
  52:src/hallinterrupts.c **** // then mods will need to be made.
  53:src/hallinterrupts.c **** //////////////////////////////////////////////////////////////
  54:src/hallinterrupts.c **** 
  55:src/hallinterrupts.c **** 
  56:src/hallinterrupts.c **** 
  57:src/hallinterrupts.c **** //////////////////////////////////////////////////////////////
  58:src/hallinterrupts.c **** // this is the Hall data we gather, and can be read directly elsewhere
  59:src/hallinterrupts.c **** // it CAN be read with interrupts disabled using
  60:src/hallinterrupts.c **** // void HallInterruptReadPosn( HALL_POSN *p, int Reset )
