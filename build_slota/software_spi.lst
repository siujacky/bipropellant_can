   4:inc/software_spi.h **** #include <stdint.h>
   5:inc/software_spi.h **** 
   6:inc/software_spi.h **** // Software SPI Pin Configuration — confirmed working 2026-06-24
   7:inc/software_spi.h **** // SO(MISO)=PB10  SI(MOSI)=PB11  CS=PA2  SCK=PA3
   8:inc/software_spi.h **** #define SOFT_SPI_MOSI_PORT    GPIOB
   9:inc/software_spi.h **** #define SOFT_SPI_MOSI_PIN     GPIO_PIN_11  // PB11 → MCP2515 SI
  10:inc/software_spi.h **** #define SOFT_SPI_MISO_PORT    GPIOB
  11:inc/software_spi.h **** #define SOFT_SPI_MISO_PIN     GPIO_PIN_10  // PB10 ← MCP2515 SO
  12:inc/software_spi.h **** #define SOFT_SPI_SCK_PORT     GPIOA
  13:inc/software_spi.h **** #define SOFT_SPI_SCK_PIN      GPIO_PIN_3   // PA3  → MCP2515 SCK
  14:inc/software_spi.h **** #define SOFT_SPI_CS_PORT      GPIOA
  15:inc/software_spi.h **** #define SOFT_SPI_CS_PIN       GPIO_PIN_2   // PA2  → MCP2515 /CS
  16:inc/software_spi.h **** #define SOFT_SPI_INT_PORT     GPIOB
  17:inc/software_spi.h **** #define SOFT_SPI_INT_PIN      GPIO_PIN_12  // PB12 (Free pin)
  18:inc/software_spi.h **** 
  19:inc/software_spi.h **** // SPI Mode Configuration
  20:inc/software_spi.h **** #define SPI_MODE0   0  // CPOL=0, CPHA=0
  21:inc/software_spi.h **** #define SPI_MODE1   1  // CPOL=0, CPHA=1
  22:inc/software_spi.h **** #define SPI_MODE2   2  // CPOL=1, CPHA=0
  23:inc/software_spi.h **** #define SPI_MODE3   3  // CPOL=1, CPHA=1
  24:inc/software_spi.h **** 
  25:inc/software_spi.h **** // Function Prototypes
  26:inc/software_spi.h **** void SoftSPI_Init(void);
  27:inc/software_spi.h **** void SoftSPI_Deinit(void);
  28:inc/software_spi.h **** uint8_t SoftSPI_Transfer(uint8_t data);
  29:inc/software_spi.h **** void SoftSPI_TransferBuffer(uint8_t *txData, uint8_t *rxData, uint16_t length);
  30:inc/software_spi.h **** void SoftSPI_CS_Low(void);
  31:inc/software_spi.h **** void SoftSPI_CS_High(void);
