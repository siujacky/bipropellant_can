   6:inc/software_spi.h **** // Software SPI Pin Configuration
   7:inc/software_spi.h **** // Using shared pins with USART2/USART3 for auto-detection
   8:inc/software_spi.h **** #define SOFT_SPI_MOSI_PORT    GPIOA
   9:inc/software_spi.h **** #define SOFT_SPI_MOSI_PIN     GPIO_PIN_2   // PA2 (USART2_TX)
  10:inc/software_spi.h **** #define SOFT_SPI_MISO_PORT    GPIOA
  11:inc/software_spi.h **** #define SOFT_SPI_MISO_PIN     GPIO_PIN_3   // PA3 (USART2_RX)
  12:inc/software_spi.h **** #define SOFT_SPI_SCK_PORT     GPIOB
  13:inc/software_spi.h **** #define SOFT_SPI_SCK_PIN      GPIO_PIN_10  // PB10 (USART3_TX)
  14:inc/software_spi.h **** #define SOFT_SPI_CS_PORT      GPIOB
  15:inc/software_spi.h **** #define SOFT_SPI_CS_PIN       GPIO_PIN_11  // PB11 (USART3_RX)
  16:inc/software_spi.h **** #define SOFT_SPI_INT_PORT     GPIOB
  17:inc/software_spi.h **** #define SOFT_SPI_INT_PIN      GPIO_PIN_12  // PB12 (Free pin)
  18:inc/software_spi.h **** 
  19:inc/software_spi.h **** // SPI Mode Configuration
  20:inc/software_spi.h **** #define SPI_MODE0   0  // CPOL=0, CPHA=0
  21:inc/software_spi.h **** #define SPI_MODE1   1  // CPOL=0, CPHA=1
  22:inc/software_spi.h **** #define SPI_MODE2   2  // CPOL=1, CPHA=0
  23:inc/software_spi.h **** #define SPI_MODE3   3  // CPOL=1, CPHA=1
  24:inc/software_spi.h **** 
